{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "cloudscale/code-block",
    "version": "1.7.50",
    "title": "CloudScale Code Block",
    "category": "formatting",
    "icon": "editor-code",
    "description": "Syntax highlighted code block with auto language detection, clipboard copy, and dark/light mode toggle.",
    "keywords": [ "code", "syntax", "highlight", "cloudscale", "developer", "programming" ],
    "supports": {
        "html": false,
        "multiple": true,
        "className": true
    },
    "attributes": {
        "content": {
            "type": "string",
            "default": ""
        },
        "language": {
            "type": "string",
            "default": ""
        },
        "title": {
            "type": "string",
            "default": ""
        },
        "theme": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "cloudscale-devtools",
    "editorStyle": "csdt-code-block-editor",
    "style": "csdt-code-block-frontend",
    "viewScript": "csdt-code-block-frontend"
}
